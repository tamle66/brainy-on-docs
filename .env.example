# ==========================================
# CẤU HÌNH CHO LARK APP
# Lấy từ Lark Developer Console (https://open.larksuite.com/app)
# ==========================================
appID=cli_xxxxxxxxxxxxxxxx
appSecret=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
blockTypeID=blk_xxxxxxxxxxxxxxxxxxxxxxxx
# ==========================================
# CẤU HÌNH KẾT NỐI FRONTEND - BACKEND
# ==========================================
# URL của Backend API (khi chạy local là http://localhost:3001, khi deploy là URL thật)
BACKEND_URL=http://localhost:3001

# ==========================================
# CẤU HÌNH BẢO MẬT & PROXY
# (Sử dụng để authenticate request từ Frontend -> Backend)
# ==========================================
AIPROXY_HEADER_AUTH_NAME=Authorization
AIPROXY_HEADER_AUTH_VALUE=your-secure-token-here
